---
import Base from '../layouts/Base.astro';

// ——— Melissa's original watercolors (the Studio Wall) ———
const gallery = [
  { src: '/images/art/flow.jpg',              title: 'Flow',                   note: 'Watercolor & ink' },
  { src: '/images/art/hokkaido-sunset.jpg',   title: 'Hokkaido Sunset',        note: 'Watercolor & ink' },
  { src: '/images/art/blossom.jpg',           title: 'Blossom',                note: 'Watercolor & ink' },
  { src: '/images/art/tides.jpg',             title: 'Tides',                  note: 'Watercolor & ink' },
  { src: '/images/art/petals.jpg',            title: 'Petals',                 note: 'Watercolor, ink & gold' },
  { src: '/images/art/elements-come-together.jpg', title: 'Elements Come Together', note: 'Watercolor' },
  { src: '/images/art/movement.jpg',          title: 'Movement',               note: 'Watercolor & ink' },
  { src: '/images/art/pastels.jpg',           title: 'Pastels',                note: 'Watercolor' },
  { src: '/images/art/ripple.jpg',            title: 'Ripple',                 note: 'Watercolor & ink' },
  { src: '/images/art/color-circuit.jpg',     title: 'Color Circuit',          note: 'Watercolor & ink' },
  { src: '/images/art/bloom.jpg',             title: 'Bloom',                  note: 'Watercolor' },
  { src: '/images/art/family-portrait-2023.jpg', title: 'Family Portrait, 2023', note: 'Watercolor & ink' },
];

// ——— Botanical studies (small works) ———
const botanicals = [
  { src: '/images/art/fern.jpg',       title: 'Fern' },
  { src: '/images/art/baby-fern.jpg',  title: 'Baby Fern' },
  { src: '/images/art/pine.jpg',       title: 'Pine' },
  { src: '/images/art/snowflake.jpg',  title: 'Snowflake' },
];

// ——— Free coloring pages ———
const coloring = [
  { img: '/images/coloring/gathered-bouquet.jpg', pdf: '/downloads/coloring-gathered-bouquet.pdf', title: 'A Gathered Bouquet' },
  { img: '/images/coloring/crown-of-flowers.jpg', pdf: '/downloads/coloring-crown-of-flowers.pdf', title: 'Crown of Flowers' },
  { img: '/images/coloring/heart-of-flowers.jpg', pdf: '/downloads/coloring-heart-of-flowers.pdf', title: 'Heart of Flowers' },
  { img: '/images/coloring/fern-leaf.jpg',        pdf: '/downloads/coloring-fern-leaf.pdf',        title: 'Fern Leaf' },
];

// ——— The Studio Shop ———
const shop = [
  { img: '/images/shop/shawl-fire-and-ice.jpg',  name: 'Fire & Ice Shawl',                 meta: 'Hand-crocheted · Navy, rose & silver', price: '$98',  badge: 'New' },
  { img: '/images/shop/shawl-warm-colors.jpg',   name: 'Warm Colors Fringe Shawl',         meta: 'Hand-crocheted · Amber, plum & navy',  price: '$96' },
  { img: '/images/shop/shawl-aqua-colors.jpg',   name: 'Aqua Colors Fringe Shawl',         meta: 'Hand-crocheted · Teal & cream',        price: '$92' },
  { img: '/images/shop/neck-oceania.jpg',        name: 'Oceania — Statement Neck Piece',   meta: 'Hand-crocheted · Deep sea blues',      price: '$72', badge: 'One of a kind' },
  { img: '/images/shop/neck-earthy.jpg',         name: 'Earthy — Statement Neck Piece',    meta: 'Hand-crocheted · Forest & spice',      price: '$68', badge: 'One of a kind' },
  { img: '/images/shop/neck-splash-of-lime.jpg', name: 'Splash of Lime — Statement Neck Piece', meta: 'Hand-crocheted · Blush & citrus', price: '$64', badge: 'One of a kind' },
  { img: '/images/shop-sweater-1.jpg',           name: 'Rainbow Crochet Cardigan',         meta: 'Hand-crocheted · Multicolor yarn',     price: '$148' },
  { img: '/images/shop-sweater-2.jpg',           name: 'Berry Crochet Jacket',             meta: 'Hand-crocheted · Pink & plum',         price: '$138' },
  { img: '/images/art/hokkaido-sunset.jpg',      name: 'Hokkaido Sunset — Art Print',      meta: 'Original watercolor · Archival paper', price: '$45' },
];
---
<Base>

  <!-- ============ HERO ============ -->
  <section class="hero" id="top">
    <div class="hero-inner">
      <div class="hero-copy">
        <p class="hero-eyebrow">Where creativity becomes care</p>
        <h1>The calm you're<br />looking for is <em>woven<br />within</em> you</h1>
        <p class="hero-sub">Melissa guides women — especially mothers — in building a personal practice of creativity and care. So you can feel more grounded, more yourself, and more present for the people who matter most.</p>
        <div class="hero-ctas">
          <a class="btn-primary" href="/#work">Work with Melissa</a>
          <a class="btn-secondary" href="/#gallery">See the Art</a>
        </div>
      </div>
      <div class="hero-art" aria-hidden="true">
        <figure class="hero-card hc-1"><img src="/images/art/flow.jpg" alt="" loading="eager" /></figure>
        <figure class="hero-card hc-2"><img src="/images/art/hokkaido-sunset.jpg" alt="" loading="eager" /></figure>
        <figure class="hero-card hc-3"><img src="/images/art/blossom.jpg" alt="" loading="eager" /></figure>
        <p class="hero-art-caption">Flow · Hokkaido Sunset · Blossom — originals by Melissa</p>
      </div>
    </div>
    <div class="hero-scroll-cue"><span>Explore</span><div class="scroll-line"></div></div>
  </section>

  <!-- ============ TAGLINE BANNER ============ -->
  <section class="tagline-band">
    <img class="band-bee" src="/images/art-bee.png" alt="" aria-hidden="true" />
    <p>Being a parent and navigating life can sometimes be challenging. When working with me, I will creatively guide you to find tools that will help <strong>support your nervous system</strong>, so that you can have more space for living a more <strong>authentic experience</strong>.</p>
    <p class="band-sig">— Melissa</p>
  </section>

  <!-- ============ ABOUT ============ -->
  <section class="section-pad" id="about">
    <div class="section-center about-grid">
      <div class="about-photo reveal">
        <img src="/images/melissa-portrait.jpg" alt="Melissa — Creative Life Coach and founder of Woven Within" loading="lazy" />
        <figure class="about-art-peek"><img src="/images/art/bee-art.jpg" alt="" aria-hidden="true" loading="lazy" /></figure>
      </div>
      <div class="about-copy reveal">
        <p class="section-eyebrow">Meet Melissa</p>
        <h2 class="section-title">A space where<br />creativity <em>heals</em></h2>
        <p class="section-body">Woven Within was born from a simple truth: when a mother tends to her own inner world, the whole family feels it.</p>
        <p class="section-body">Melissa guides women — especially mothers — in using creativity, beauty, and reflection as tools for nervous system support and deep personal grounding. This isn't about making art that's perfect or following a wellness formula. It's about giving yourself permission to slow down, create something with your hands, and notice what shifts inside you when you do.</p>
        <p class="section-body">This isn't therapy. It isn't a rigid curriculum. It's a living, breathing practice of noticing, creating, and reconnecting with yourself so you can show up with more calm, presence, and care for the people who matter most.</p>
        <blockquote class="about-quote">"When we tend to our own creative spirit, we become the steady center our families need."</blockquote>
      </div>
    </div>
  </section>

  <!-- ============ APPROACH ============ -->
  <section class="section-pad approach" id="approach">
    <div class="section-center">
      <div class="approach-head reveal">
        <p class="section-eyebrow">The Approach</p>
        <h2 class="section-title">Creative Life Coaching,<br /><em>reimagined</em></h2>
        <p class="section-body">Melissa's work weaves together creativity, nervous system awareness, and soulful practice to help you feel more grounded, expressive, and whole — not just as a mother, but as a woman. This isn't coaching with a rigid framework. It's a deeply personal practice, guided by someone who has walked this path herself.</p>
      </div>
      <div class="approach-cards">
        <article class="approach-card reveal">
          <div class="approach-mark">✦</div>
          <h3>Creative Expression</h3>
          <p>Art, craft, and beauty as pathways to self-understanding. Not about the outcome — about the practice of presence and making something with your hands. When you create, you listen. When you listen, you begin to come home to yourself.</p>
        </article>
        <article class="approach-card reveal">
          <div class="approach-mark">◯</div>
          <h3>Nervous System Care</h3>
          <p>Gentle, accessible practices that help your body find regulation. Learn to recognize what your system needs and how creativity can become a grounding tool. This isn't clinical work — it's learning to notice, soften, and give yourself what you actually need in any given moment.</p>
        </article>
        <article class="approach-card reveal">
          <div class="approach-mark">◈</div>
          <h3>Family Co-Regulation</h3>
          <p>When you feel centered and supported, your calm becomes contagious. Explore how your personal practice ripples outward to support your whole household. Children, partners, and the rhythm of daily life all benefit when the mother at the center has tended to her own steadiness.</p>
        </article>
      </div>
    </div>
  </section>

  <!-- ============ GALLERY — THE STUDIO WALL ============ -->
  <section class="section-pad gallery" id="gallery">
    <div class="section-center">
      <div class="gallery-head reveal">
        <p class="section-eyebrow">From Melissa's Studio</p>
        <h2 class="section-title">The Studio <em>Wall</em></h2>
        <p class="section-body">Every piece here began the way I hope your practice will: a quiet moment, a brush, and permission to see what emerges. These are original watercolors from my own daily practice — the same practice I'll help you build. Tap any piece to see it up close.</p>
      </div>

      <div class="gallery-grid">
        {gallery.map((piece, i) => (
          <button class="gallery-item reveal" data-index={i} aria-label={`View ${piece.title}`}>
            <img src={piece.src} alt={`${piece.title} — original watercolor by Melissa`} loading="lazy" />
            <span class="gallery-caption">{piece.title}</span>
          </button>
        ))}
      </div>

      <div class="botanical-strip reveal">
        <p class="botanical-label">Botanical studies</p>
        <div class="botanical-row">
          {botanicals.map((piece, i) => (
            <button class="botanical-item" data-index={gallery.length + i} aria-label={`View ${piece.title}`}>
              <img src={piece.src} alt={`${piece.title} — botanical watercolor study by Melissa`} loading="lazy" />
              <span>{piece.title}</span>
            </button>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Lightbox -->
  <dialog class="lightbox" id="lightbox">
    <button class="lb-close" id="lbClose" aria-label="Close">×</button>
    <button class="lb-nav lb-prev" id="lbPrev" aria-label="Previous piece">‹</button>
    <figure>
      <img id="lbImg" src="" alt="" />
      <figcaption><span id="lbTitle"></span><em id="lbNote"></em></figcaption>
    </figure>
    <button class="lb-nav lb-next" id="lbNext" aria-label="Next piece">›</button>
  </dialog>

  <!-- ============ FOR MOTHERS ============ -->
  <section class="section-pad mothers">
    <div class="section-center mothers-grid">
      <div class="mothers-copy reveal">
        <p class="section-eyebrow">For Mothers &amp; Family Life</p>
        <h2 class="section-title">When a mother <em>feels</em><br />centered, the whole<br />home shifts</h2>
        <p class="section-body">You don't need another productivity system. You don't need a five-step plan or a morning routine borrowed from someone whose life looks nothing like yours.</p>
        <p class="section-body">You need space to breathe, create, and remember who you are beyond the daily rhythm of caring for others. This work starts with you — and transforms everything around you.</p>
      </div>
      <div class="mothers-points">
        <div class="mother-point reveal"><h4>More calm, less depletion</h4><p>Build a personal practice that refills your cup through beauty, reflection, and creative expression — not another obligation on your list, but something that genuinely nourishes you.</p></div>
        <div class="mother-point reveal"><h4>A steadier nervous system</h4><p>Learn to notice when you're dysregulated and gently guide yourself back to a grounded place. Not through force or willpower, but through creative practices your body actually responds to.</p></div>
        <div class="mother-point reveal"><h4>Deeper family connection</h4><p>When you co-regulate from a centered place, your children and partner can feel the shift. You don't have to explain it. They simply feel it in the way you move through your day.</p></div>
        <div class="mother-point reveal"><h4>Creative reconnection</h4><p>Rediscover the part of yourself that creates, imagines, and finds meaning in beauty. The part that may have gone quiet in the busyness of motherhood, but never left.</p></div>
      </div>
    </div>
  </section>

  <!-- ============ WORK TOGETHER ============ -->
  <section class="section-pad work" id="work">
    <div class="section-center">
      <div class="work-head reveal">
        <p class="section-eyebrow">Ways to Work Together</p>
        <h2 class="section-title">Find your path <em>inward</em></h2>
        <p class="section-body">Whether you're craving one-on-one support or a creative community, there's a way to begin that feels right for where you are. No pressure, no rigid timelines — just an open door.</p>
      </div>
      <div class="work-cards">
        <article class="work-card reveal">
          <div class="work-img"><img src="/images/art/movement.jpg" alt="Movement — original watercolor by Melissa" loading="lazy" /></div>
          <p class="work-kind">Private Coaching</p>
          <h3>Creative Life Sessions</h3>
          <p>Intimate, one-on-one sessions combining creative exploration, nervous system support, and personal reflection. Tailored entirely to your season of life — whether you're navigating early motherhood, a creative dry spell, or a quiet longing for something more. Melissa meets you exactly where you are.</p>
          <a href="/#contact" class="work-link">Learn More →</a>
        </article>
        <article class="work-card reveal">
          <div class="work-img"><img src="/images/art/pastels.jpg" alt="Pastels — original watercolor by Melissa" loading="lazy" /></div>
          <p class="work-kind">Group Experience</p>
          <h3>The Woven Circle</h3>
          <p>A small, seasonal gathering for mothers who want to create together, share honestly, and build a supportive practice rooted in beauty and care. This is not group therapy. It's a creative circle — a held space where women can be seen, make something beautiful, and remember they're not carrying this alone.</p>
          <a href="/#contact" class="work-link">Learn More →</a>
        </article>
        <article class="work-card reveal">
          <div class="work-img"><img src="/images/coloring/crown-of-flowers.jpg" alt="Crown of Flowers — original line drawing by Melissa" loading="lazy" /></div>
          <p class="work-kind">Creative Resources</p>
          <h3>Grounding Guides</h3>
          <p>Beautifully designed reflective guides, creative prompts, and gentle practices you can weave into your daily rhythm at your own pace. Think of these as quiet invitations — not assignments. Each one is crafted to help you slow down, create, and notice what emerges when you give yourself permission to be present.</p>
          <a href="/#coloring" class="work-link">Start with a free page →</a>
        </article>
      </div>
    </div>
  </section>

  <!-- ============ FREE COLORING PAGES ============ -->
  <section class="section-pad coloring" id="coloring">
    <div class="section-center">
      <div class="coloring-head reveal">
        <p class="section-eyebrow">A gift, from my hands to yours</p>
        <h2 class="section-title">Slow down &amp; <em>color</em></h2>
        <p class="section-body">These are original line drawings from my sketchbook, made into printable coloring pages. Print one, gather whatever colors you have, and give yourself ten unhurried minutes. That's the whole practice. No signup, no strings — just an invitation to begin.</p>
      </div>
      <div class="coloring-grid">
        {coloring.map((page) => (
          <article class="coloring-card reveal">
            <div class="coloring-img"><img src={page.img} alt={`${page.title} — printable coloring page by Melissa`} loading="lazy" /></div>
            <h3>{page.title}</h3>
            <a class="btn-secondary coloring-btn" href={page.pdf} download>Download PDF</a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ============ SHOP ============ -->
  <section class="section-pad shop" id="shop">
    <div class="section-center">
      <div class="shop-head reveal">
        <p class="section-eyebrow">The Studio Shop</p>
        <h2 class="section-title">Handmade with <em>care</em></h2>
        <p class="section-body">Every piece is made by hand — slowly, intentionally, and with the same philosophy of care that runs through all of Woven Within. From hand-crocheted shawls and one-of-a-kind statement neck pieces to original art prints, each item carries the spirit of making as a form of care.</p>
        <a class="btn-secondary" href="/#contact">Ask About a Piece</a>
      </div>
      <div class="shop-grid">
        {shop.map((item) => (
          <article class="shop-card reveal">
            <div class="shop-img">
              <img src={item.img} alt={`${item.name} — ${item.meta}`} loading="lazy" />
              {item.badge && <span class="shop-badge">{item.badge}</span>}
            </div>
            <div class="shop-info">
              <h3>{item.name}</h3>
              <p>{item.meta}</p>
              <span class="shop-price">{item.price}</span>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ============ PHILOSOPHY ============ -->
  <section class="section-pad philosophy">
    <div class="section-narrow reveal">
      <img class="phil-mark" src="/images/art-honeycomb.png" alt="" aria-hidden="true" />
      <blockquote class="phil-quote">"I believe every woman carries a creative knowing inside her — a thread of beauty, care, and <strong>quiet strength</strong> that, when tended to, becomes the most powerful gift she can offer her family."</blockquote>
      <p class="phil-body">Woven Within grew from my own journey as a mother learning to trust creativity as a form of care. Through art, handwork, reflection, and learning to listen to my nervous system, I found a steadiness I didn't know was possible — and I watched it change everything in my home. Not dramatically, not overnight. But in the way the air shifts when someone in the house finally takes a full breath.</p>
      <p class="phil-body">This work is deeply personal. It's rooted in my life, my heritage, and the women who taught me that beauty is never separate from survival. I grew up watching hands weave, knit, and create things of stunning care out of very little. That making — that creative devotion — is the root of everything I do.</p>
      <p class="phil-body">I created Woven Within to offer other mothers what I wished someone had offered me: permission to tend to yourself, and a beautiful space to do it in. Not a program with deadlines. Not a course with grades. A practice. A relationship with your own creative spirit. A reminder that the calm and beauty you're looking for was always woven within you.</p>
      <p class="phil-sig">— Melissa</p>
    </div>
  </section>

  <!-- ============ NEWSLETTER ============ -->
  <section class="section-pad newsletter" id="newsletter">
    <div class="section-narrow reveal">
      <p class="section-eyebrow">Stay Connected</p>
      <h2 class="section-title">Gentle words,<br /><em>creative nourishment</em></h2>
      <p class="section-body">A thoughtful letter from Melissa with reflections, creative invitations, and small beautiful things — sent with care, never clutter. Each letter is written the way I'd write to a friend: honest, warm, and with something worth sitting with.</p>
      <div class="newsletter-form">
        <input type="email" placeholder="Your email address" aria-label="Email address" />
        <button class="btn-primary" type="button">Join the Thread</button>
      </div>
      <p class="newsletter-note">Sent seasonally. Unsubscribe anytime. Your inbox is sacred.</p>
    </div>
  </section>

  <!-- ============ JOURNAL ============ -->
  <section class="section-pad journal" id="journal">
    <div class="section-center">
      <div class="journal-head reveal">
        <div>
          <p class="section-eyebrow">The Journal</p>
          <h2 class="section-title">Reflections &amp; <em>invitations</em></h2>
        </div>
        <a class="btn-secondary" href="/#journal">Read All Entries</a>
      </div>
      <div class="journal-grid">
        <article class="journal-card reveal">
          <div class="journal-img"><img src="/images/art/fern.jpg" alt="Fern — botanical watercolor by Melissa" loading="lazy" /></div>
          <p class="journal-tag">Creativity &amp; Care</p>
          <h3><a href="#">What I Mean When I Say "Creative Life Coaching"</a></h3>
          <p>It's not about painting a masterpiece. It's about using your hands, your eyes, and your attention as tools for coming home to yourself.</p>
        </article>
        <article class="journal-card reveal">
          <div class="journal-img"><img src="/images/art/snowflake.jpg" alt="Snowflake — botanical watercolor by Melissa" loading="lazy" /></div>
          <p class="journal-tag">Nervous System</p>
          <h3><a href="#">The Quiet Practice That Changed My Mornings</a></h3>
          <p>Five minutes before anyone wakes up. A cup of something warm. And a very small creative act that rewired my whole day.</p>
        </article>
        <article class="journal-card reveal">
          <div class="journal-img"><img src="/images/art/pine.jpg" alt="Pine — botanical watercolor by Melissa" loading="lazy" /></div>
          <p class="journal-tag">Motherhood</p>
          <h3><a href="#">Co-Regulation Starts with You</a></h3>
          <p>Your children don't need a perfect mother. They need a mother who is learning to tend to her own steadiness — and letting them witness the practice.</p>
        </article>
      </div>
    </div>
  </section>

  <script define:vars={{ pieces: [...gallery, ...botanicals.map(b => ({ ...b, note: 'Botanical study · Watercolor & ink' }))] }}>
    const lb = document.getElementById('lightbox');
    const lbImg = document.getElementById('lbImg');
    const lbTitle = document.getElementById('lbTitle');
    const lbNote = document.getElementById('lbNote');
    let current = 0;

    function show(i) {
      current = (i + pieces.length) % pieces.length;
      const p = pieces[current];
      lbImg.src = p.src;
      lbImg.alt = `${p.title} — original artwork by Melissa`;
      lbTitle.textContent = p.title;
      lbNote.textContent = p.note || '';
    }
    document.querySelectorAll('.gallery-item, .botanical-item').forEach(btn => {
      btn.addEventListener('click', () => { show(Number(btn.dataset.index)); lb.showModal(); });
    });
    document.getElementById('lbClose').addEventListener('click', () => lb.close());
    document.getElementById('lbPrev').addEventListener('click', () => show(current - 1));
    document.getElementById('lbNext').addEventListener('click', () => show(current + 1));
    lb.addEventListener('click', (e) => { if (e.target === lb) lb.close(); });
    lb.addEventListener('keydown', (e) => {
      if (e.key === 'ArrowLeft') show(current - 1);
      if (e.key === 'ArrowRight') show(current + 1);
    });
  </script>

  <style>
    /* ===== HERO ===== */
    .hero { min-height: 100vh; display: flex; align-items: center; padding: calc(var(--nav-h) + 40px) clamp(24px, 5vw, 80px) 80px; background: linear-gradient(175deg, var(--cream) 55%, var(--cream-deep) 100%); }
    .hero-inner { max-width: 1240px; margin: 0 auto; display: grid; grid-template-columns: 1.05fr 1fr; gap: clamp(40px, 6vw, 90px); align-items: center; width: 100%; }
    .hero-eyebrow { font-family: var(--font-accent); font-size: 1.5rem; color: var(--rose); margin-bottom: 18px; }
    .hero h1 { font-family: var(--font-display); font-size: clamp(2.7rem, 5.4vw, 4.4rem); font-weight: 300; color: var(--plum-deep); line-height: 1.1; margin-bottom: 26px; }
    .hero h1 em { font-style: italic; font-weight: 400; color: var(--rose); }
    .hero-sub { font-size: 1.05rem; font-weight: 300; color: var(--text-light); line-height: 1.85; max-width: 480px; margin-bottom: 36px; }
    .hero-ctas { display: flex; gap: 16px; flex-wrap: wrap; }

    .hero-art { position: relative; height: clamp(360px, 42vw, 540px); }
    .hero-card { position: absolute; border-radius: 10px; overflow: hidden; background: #fff; padding: 10px 10px 14px; box-shadow: 0 24px 60px rgba(92,54,81,0.16); transition: transform 0.5s ease; }
    .hero-card img { border-radius: 4px; width: 100%; height: 100%; object-fit: cover; }
    .hc-1 { width: 58%; height: 62%; top: 2%; left: 0; transform: rotate(-4deg); z-index: 1; }
    .hc-2 { width: 56%; height: 58%; top: 22%; right: 0; transform: rotate(3deg); z-index: 2; }
    .hc-3 { width: 50%; height: 52%; bottom: 0; left: 16%; transform: rotate(-1.5deg); z-index: 3; }
    .hero-card:hover { transform: rotate(0deg) translateY(-6px); z-index: 5; }
    .hero-art-caption { position: absolute; bottom: -34px; left: 0; right: 0; text-align: center; font-family: var(--font-accent); font-size: 1.05rem; color: var(--text-light); }

    .hero-scroll-cue { position: absolute; bottom: 32px; left: 50%; transform: translateX(-50%); display: flex; flex-direction: column; align-items: center; gap: 8px; }
    .hero-scroll-cue span { font-size: 0.7rem; letter-spacing: 0.15em; text-transform: uppercase; color: var(--text-light); }
    .scroll-line { width: 1px; height: 40px; background: linear-gradient(to bottom, var(--rose), transparent); animation: scrollPulse 2s ease-in-out infinite; }
    @keyframes scrollPulse { 0%,100% { opacity: 0.3; transform: scaleY(0.6); } 50% { opacity: 1; transform: scaleY(1); } }

    /* ===== TAGLINE BAND ===== */
