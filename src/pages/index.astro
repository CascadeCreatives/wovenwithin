---
import Base from '../layouts/Base.astro';
---

<Base>

<!-- ===== HERO ===== -->
<section class="hero">
  <div class="hero-gradient"></div>
  <div class="hero-orbs">
    <div class="orb orb-1"></div><div class="orb orb-2"></div>
    <div class="orb orb-3"></div><div class="orb orb-4"></div>
  </div>
  <div class="hero-geo">
    <svg viewBox="0 0 1440 900" fill="none" xmlns="http://www.w3.org/2000/svg" style="width:100%;height:100%;">
      <path d="M100 200 L160 120 L220 200 L160 280Z" stroke="#7B4A6B" stroke-width="0.4" opacity="0.08"/>
      <path d="M1200 100 L1260 20 L1320 100 L1260 180Z" stroke="#D4727E" stroke-width="0.4" opacity="0.06"/>
      <path d="M300 600 L360 520 L420 600 L360 680Z" stroke="#A8CBE0" stroke-width="0.4" opacity="0.05"/>
      <path d="M1100 500 L1160 420 L1220 500 L1160 580Z" stroke="#B498C4" stroke-width="0.4" opacity="0.05"/>
    </svg>
  </div>
  <img class="art-honeycomb-hero" src="/images/art-honeycomb.png" alt="" aria-hidden="true" />
  <div class="hero-content">
    <p class="hero-eyebrow">Where creativity becomes care</p>
    <h1 class="hero-h1">The calm you're<br/>looking for is <em>woven<br/>within</em> you</h1>
    <p class="hero-sub">Melissa guides women — especially mothers — in building a personal practice of creativity and care. So you can feel more grounded, more yourself, and more present for the people who matter most.</p>
    <div class="hero-btns">
      <a href="/work" class="btn btn-fill">Work with Melissa</a>
      <a href="/approach" class="btn btn-outline">Discover the Approach</a>
    </div>
  </div>
  <div class="hero-scroll"><span>Explore</span><div class="scroll-pip"></div></div>
</section>

<!-- ===== MELISSA'S TAGLINE ===== -->
<section class="tagline-banner">
  <div class="tagline-bg-accent left"></div>
  <div class="tagline-bg-accent right"></div>
  <img class="art-bee" src="/images/art-bee.png" alt="" aria-hidden="true" />
  <div class="tagline-inner">
    <div class="tagline-deco rv"><div class="line"></div><div class="diamond"></div><div class="diamond"></div><div class="diamond"></div><div class="line"></div></div>
    <p class="tagline-text rv rv-d1">Being a parent and navigating life can sometimes be challenging. When working with me, I will creatively guide you to find tools that will help <strong>support your nervous system</strong>, so that you can have more space for living a more <strong>authentic experience</strong>.</p>
    <span class="tagline-attr rv rv-d2">— Melissa</span>
  </div>
</section>

<!-- ===== ABOUT / INTRO ===== -->
<section class="intro sec-pad" id="about">
  <div class="sec-center">
    <div class="intro-grid">
      <div class="intro-img-wrap rv">
        <div class="intro-img">
          <img src="/images/melissa-portrait.jpg" alt="Melissa — Creative Life Coach and founder of Woven Within" style="width:100%;height:100%;object-fit:cover;object-position:center 20%;display:block;" />
        </div>
        <div class="intro-img-accent"></div>
      </div>
      <div class="intro-text">
        <p class="sec-eyebrow rv">Meet Melissa</p>
        <h2 class="sec-h2 rv rv-d1">A space where<br/>creativity <em>heals</em></h2>
        <p class="sec-body rv rv-d2">Woven Within was born from a simple truth: when a mother tends to her own inner world, the whole family feels it.</p>
        <p class="sec-body rv rv-d2">Melissa guides women — especially mothers — in using creativity, beauty, and reflection as tools for nervous system support and deep personal grounding. This isn't about making art that's perfect or following a wellness formula. It's about giving yourself permission to slow down, create something with your hands, and notice what shifts inside you when you do.</p>
        <p class="sec-body rv rv-d3">This isn't therapy. It isn't a rigid curriculum. It's a living, breathing practice of noticing, creating, and reconnecting with yourself so you can show up with more calm, presence, and care for the people who matter most.</p>
        <p class="intro-quote rv rv-d4">"When we tend to our own creative spirit, we become the steady center our families need."</p>
      </div>
    </div>
  </div>
</section>

<div class="divider"><div class="d-line"></div><div class="d-dia"></div><div class="d-dia"></div><div class="d-dia"></div><div class="d-line"></div></div>

<!-- ===== APPROACH ===== -->
<section class="approach sec-pad" id="approach">
  <div class="sec-center">
    <div class="approach-header">
      <p class="sec-eyebrow rv">The Approach</p>
      <h2 class="sec-h2 rv rv-d1">Creative Life Coaching,<br/><em>reimagined</em></h2>
      <p class="sec-body rv rv-d2">Melissa's work weaves together creativity, nervous system awareness, and soulful practice to help you feel more grounded, expressive, and whole — not just as a mother, but as a woman. This isn't coaching with a rigid framework. It's a deeply personal practice, guided by someone who has walked this path herself.</p>
    </div>
    <div class="pillars">
      <div class="pillar rv">
        <div class="pillar-icon">✦</div>
        <h3 class="pillar-title">Creative Expression</h3>
        <p class="pillar-body">Art, craft, and beauty as pathways to self-understanding. Not about the outcome — about the practice of presence and making something with your hands. When you create, you listen. When you listen, you begin to come home to yourself.</p>
      </div>
      <div class="pillar rv rv-d1">
        <div class="pillar-icon">◯</div>
        <h3 class="pillar-title">Nervous System Care</h3>
        <p class="pillar-body">Gentle, accessible practices that help your body find regulation. Learn to recognize what your system needs and how creativity can become a grounding tool. This isn't clinical work — it's learning to notice, soften, and give yourself what you actually need in any given moment.</p>
      </div>
      <div class="pillar rv rv-d2">
        <div class="pillar-icon">◈</div>
        <h3 class="pillar-title">Family Co-Regulation</h3>
        <p class="pillar-body">When you feel centered and supported, your calm becomes contagious. Explore how your personal practice ripples outward to support your whole household. Children, partners, and the rhythm of daily life all benefit when the mother at the center has tended to her own steadiness.</p>
      </div>
    </div>
  </div>
</section>

<!-- ===== WHY THIS MATTERS ===== -->
<section class="mothers sec-pad">
  <div class="sec-center">
    <div class="mothers-grid">
      <div>
        <p class="sec-eyebrow rv">For Mothers &amp; Family Life</p>
        <h2 class="sec-h2 rv rv-d1">When a mother <em>feels</em><br/>centered, the whole<br/>home shifts</h2>
        <p class="sec-body rv rv-d2">You don't need another productivity system. You don't need a five-step plan or a morning routine borrowed from someone whose life looks nothing like yours.</p>
        <p class="sec-body rv rv-d3" style="margin-top:16px">You need space to breathe, create, and remember who you are beyond the daily rhythm of caring for others. This work starts with you — and transforms everything around you. Not because you're broken and need fixing, but because when you tend to your own ground, the whole ecosystem of your home begins to settle.</p>
      </div>
      <div class="mothers-points">
        <div class="m-point rv"><div class="m-point-dot"><span></span></div><div><h4>More calm, less depletion</h4><p>Build a personal practice that refills your cup through beauty, reflection, and creative expression — not another obligation on your list, but something that genuinely nourishes you.</p></div></div>
        <div class="m-point rv rv-d1"><div class="m-point-dot"><span></span></div><div><h4>A steadier nervous system</h4><p>Learn to notice when you're dysregulated and gently guide yourself back to a grounded place. Not through force or willpower, but through creative practices your body actually responds to.</p></div></div>
        <div class="m-point rv rv-d2"><div class="m-point-dot"><span></span></div><div><h4>Deeper family connection</h4><p>When you co-regulate from a centered place, your children and partner can feel the shift. You don't have to explain it. They simply feel it in the way you move through your day.</p></div></div>
        <div class="m-point rv rv-d3"><div class="m-point-dot"><span></span></div><div><h4>Creative reconnection</h4><p>Rediscover the part of yourself that creates, imagines, and finds meaning in beauty. The part that may have gone quiet in the busyness of motherhood, but never left.</p></div></div>
      </div>
    </div>
  </div>
</section>

<!-- ===== WORK WITH MELISSA ===== -->
<section class="work sec-pad" id="work">
  <div class="sec-center">
    <div class="work-header">
      <p class="sec-eyebrow rv">Ways to Work Together</p>
      <h2 class="sec-h2 rv rv-d1">Find your path <em>inward</em></h2>
      <p class="sec-body rv rv-d2">Whether you're craving one-on-one support or a creative community, there's a way to begin that feels right for where you are. No pressure, no rigid timelines — just an open door.</p>
    </div>
    <div class="offerings">
      <div class="offer-card rv">
        <div class="offer-img"><span class="offer-img-label">One-on-One</span></div>
        <div class="offer-body">
          <span class="offer-tag">Private Coaching</span>
          <h3 class="offer-title">Creative Life Sessions</h3>
          <p class="offer-text">Intimate, one-on-one sessions combining creative exploration, nervous system support, and personal reflection. Tailored entirely to your season of life — whether you're navigating early motherhood, a creative dry spell, or a quiet longing for something more. Melissa meets you exactly where you are.</p>
          <a href="/work" class="btn btn-ghost">Learn More <svg viewBox="0 0 16 16" fill="none" style="width:16px;height:16px"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></a>
        </div>
      </div>
      <div class="offer-card rv rv-d1">
        <div class="offer-img"><span class="offer-img-label">Community</span></div>
        <div class="offer-body">
          <span class="offer-tag">Group Experience</span>
          <h3 class="offer-title">The Woven Circle</h3>
          <p class="offer-text">A small, seasonal gathering for mothers who want to create together, share honestly, and build a supportive practice rooted in beauty and care. This is not group therapy. It's a creative circle — a held space where women can be seen, make something beautiful, and remember they're not carrying this alone.</p>
          <a href="/work" class="btn btn-ghost">Learn More <svg viewBox="0 0 16 16" fill="none" style="width:16px;height:16px"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></a>
        </div>
      </div>
      <div class="offer-card rv rv-d2">
        <div class="offer-img"><span class="offer-img-label">Self-Guided</span></div>
        <div class="offer-body">
          <span class="offer-tag">Creative Resources</span>
          <h3 class="offer-title">Grounding Guides</h3>
          <p class="offer-text">Beautifully designed reflective guides, creative prompts, and gentle practices you can weave into your daily rhythm at your own pace. Think of these as quiet invitations — not assignments. Each one is crafted to help you slow down, create, and notice what emerges when you give yourself permission to be present.</p>
          <a href="/work" class="btn btn-ghost">Learn More <svg viewBox="0 0 16 16" fill="none" style="width:16px;height:16px"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></a>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ===== SHOP ===== -->
<section class="shop sec-pad" id="shop">
  <div class="sec-center">
    <div class="shop-top">
      <div>
        <p class="sec-eyebrow rv">The Studio Shop</p>
        <h2 class="sec-h2 rv rv-d1">Handmade with <em>care</em></h2>
        <p class="shop-intro rv rv-d2">Every piece is made by hand — slowly, intentionally, and with the same philosophy of care that runs through all of Woven Within. From hand-knit wraps to original art prints, each item carries the spirit of making as a form of care.</p>
      </div>
      <a href="/shop" class="btn btn-outline rv rv-d2">Browse All Goods</a>
    </div>
    <div class="shop-grid">
      <div class="shop-card rv">
        <div class="shop-card-img">
          <img src="/images/shop-sweater-1.jpg" alt="Rainbow Crochet Cardigan — hand-crocheted in multicolor yarn" style="width:100%;height:100%;object-fit:cover;display:block;" />
          <span class="shop-badge">New</span>
        </div>
        <p class="shop-card-name">Rainbow Crochet Cardigan</p>
        <p class="shop-card-detail">Hand-crocheted · Multicolor yarn</p>
        <p class="shop-card-price">$148</p>
      </div>
      <div class="shop-card rv rv-d1">
        <div class="shop-card-img">
          <img src="/images/shop-sweater-2.jpg" alt="Berry Crochet Jacket — hand-crocheted in pink and plum" style="width:100%;height:100%;object-fit:cover;display:block;" />
        </div>
        <p class="shop-card-name">Berry Crochet Jacket</p>
        <p class="shop-card-detail">Hand-crocheted · Pink & plum</p>
        <p class="shop-card-price">$138</p>
      </div>
      <div class="shop-card rv rv-d2">
        <div class="shop-card-img"><span class="shop-card-img-label">Botanical<br/>Art Print</span></div>
        <p class="shop-card-name">Quiet Morning — Print</p>
        <p class="shop-card-detail">Archival ink on cotton paper</p>
        <p class="shop-card-price">$45</p>
      </div>
      <div class="shop-card rv rv-d3">
        <div class="shop-card-img"><span class="shop-card-img-label">Creative<br/>Journal</span></div>
        <p class="shop-card-name">Creative Grounding Journal</p>
        <p class="shop-card-detail">Hand-bound · Guided prompts</p>
        <p class="shop-card-price">$36</p>
      </div>
    </div>
  </div>
</section>

<!-- ===== PHILOSOPHY ===== -->
<section class="philosophy sec-pad">
  <div class="phil-orb l"></div>
  <div class="phil-orb r"></div>
  <img class="art-honeycomb-phil" src="/images/art-honeycomb.png" alt="" aria-hidden="true" />
  <div class="sec-center">
    <div class="philosophy-inner">
      <div class="divider rv" style="margin-bottom:48px"><div class="d-line"></div><div class="d-dia"></div><div class="d-dia"></div><div class="d-dia"></div><div class="d-line"></div></div>
      <p class="philosophy-pull rv">"I believe every woman carries a creative knowing inside her — a thread of beauty, care, and <strong>quiet strength</strong> that, when tended to, becomes the most powerful gift she can offer her family."</p>
      <p class="philosophy-p rv rv-d1">Woven Within grew from my own journey as a mother learning to trust creativity as a form of care. Through art, handwork, reflection, and learning to listen to my nervous system, I found a steadiness I didn't know was possible — and I watched it change everything in my home. Not dramatically, not overnight. But in the way the air shifts when someone in the house finally takes a full breath.</p>
      <p class="philosophy-p rv rv-d2">This work is deeply personal. It's rooted in my life, my heritage, and the women who taught me that beauty is never separate from survival. I grew up watching hands weave, knit, and create things of stunning care out of very little. That making — that creative devotion — is the root of everything I do.</p>
      <p class="philosophy-p rv rv-d3">I created Woven Within to offer other mothers what I wished someone had offered me: permission to tend to yourself, and a beautiful space to do it in. Not a program with deadlines. Not a course with grades. A practice. A relationship with your own creative spirit. A reminder that the calm and beauty you're looking for was always woven within you.</p>
      <p class="philosophy-sig rv rv-d4">— Melissa</p>
    </div>
  </div>
</section>

<!-- ===== EMAIL SIGNUP ===== -->
<section class="signup sec-pad" id="contact">
  <div class="sec-center">
    <img class="art-honeycomb-signup" src="/images/art-honeycomb.png" alt="" aria-hidden="true" />
    <div class="signup-inner">
      <p class="sec-eyebrow rv">Stay Connected</p>
      <h2 class="sec-h2 rv rv-d1">Gentle words,<br/><em>creative nourishment</em></h2>
      <p class="sec-body rv rv-d2" style="max-width:540px;margin:0 auto 36px">A thoughtful letter from Melissa with reflections, creative invitations, and small beautiful things — sent with care, never clutter. Each letter is written the way I'd write to a friend: honest, warm, and with something worth sitting with.</p>
      <form class="signup-form rv rv-d3">
        <input type="email" placeholder="Your email address" required />
        <button type="submit" class="btn btn-fill">Join the Thread</button>
      </form>
      <p class="signup-note rv rv-d4">Sent seasonally. Unsubscribe anytime. Your inbox is sacred.</p>
    </div>
  </div>
</section>

<!-- ===== JOURNAL ===== -->
<section class="journal sec-pad" id="journal" style="overflow:hidden;">
  <img class="art-bee-journal" src="/images/art-bee.png" alt="" aria-hidden="true" />
  <div class="sec-center">
    <div class="journal-top">
      <div>
        <p class="sec-eyebrow rv">The Journal</p>
        <h2 class="sec-h2 rv rv-d1">Reflections &amp; <em>invitations</em></h2>
      </div>
      <a href="/journal" class="btn btn-outline rv rv-d2">Read All Entries</a>
    </div>
    <div class="journal-grid">
      <div class="j-card rv">
        <div class="j-card-img"></div>
        <span class="j-card-tag">Creativity & Care</span>
        <h3 class="j-card-title"><a href="#">What I Mean When I Say "Creative Life Coaching"</a></h3>
        <p class="j-card-excerpt">It's not about painting a masterpiece. It's about using your hands, your eyes, and your attention as tools for coming home to yourself.</p>
      </div>
      <div class="j-card rv rv-d1">
        <div class="j-card-img"></div>
        <span class="j-card-tag">Nervous System</span>
        <h3 class="j-card-title"><a href="#">The Quiet Practice That Changed My Mornings</a></h3>
        <p class="j-card-excerpt">Five minutes before anyone wakes up. A cup of something warm. And a very small creative act that rewired my whole day.</p>
      </div>
      <div class="j-card rv rv-d2">
        <div class="j-card-img"></div>
        <span class="j-card-tag">Motherhood</span>
        <h3 class="j-card-title"><a href="#">Co-Regulation Starts with You</a></h3>
        <p class="j-card-excerpt">Your children don't need a perfect mother. They need a mother who is learning to tend to her own steadiness — and letting them witness the practice.</p>
      </div>
    </div>
  </div>
</section>

</Base>

<style>
  /* ===== PAGE-SPECIFIC STYLES ===== */

  /* Hero */
  .hero { position: relative; min-height: 100vh; display: flex; flex-direction: column; align-items: center; justify-content: center; text-align: center; padding: calc(var(--nav-h) + 20px) clamp(20px, 5vw, 80px) 60px; overflow: hidden; }
  .hero-gradient { position: absolute; inset: 0; background: radial-gradient(ellipse 80% 60% at 25% 20%, rgba(216,200,226,0.35) 0%, transparent 70%), radial-gradient(ellipse 70% 50% at 75% 70%, rgba(245,213,217,0.4) 0%, transparent 70%), radial-gradient(ellipse 60% 40% at 50% 40%, rgba(212,230,241,0.25) 0%, transparent 70%), radial-gradient(ellipse 50% 30% at 80% 30%, rgba(232,132,92,0.08) 0%, transparent 70%), linear-gradient(175deg, var(--cream) 0%, var(--blush) 40%, var(--sand-light) 70%, var(--cream) 100%); }
  .hero-orbs { position: absolute; inset: 0; pointer-events: none; overflow: hidden; }
  .orb { position: absolute; border-radius: 50%; filter: blur(80px); }
  .orb-1 { width: 480px; height: 480px; background: var(--lavender-soft); top: -8%; right: -4%; opacity: 0.3; animation: drift 22s ease-in-out infinite; }
  .orb-2 { width: 380px; height: 380px; background: var(--rose-pale); bottom: 8%; left: -6%; opacity: 0.25; animation: drift 28s ease-in-out infinite reverse; }
  .orb-3 { width: 260px; height: 260px; background: var(--sky-pale); top: 25%; left: 12%; opacity: 0.2; animation: drift 18s ease-in-out infinite 4s; }
  .orb-4 { width: 180px; height: 180px; background: var(--coral-warm); bottom: 30%; right: 12%; opacity: 0.1; animation: drift 24s ease-in-out infinite 6s; }
  .hero-geo { position: absolute; inset: 0; pointer-events: none; opacity: 0.045; }
  .hero-content { position: relative; z-index: 2; max-width: 880px; }
  .hero-eyebrow { font-family: var(--font-accent); font-size: clamp(1.1rem, 2.5vw, 1.4rem); color: var(--rose); margin-bottom: 18px; opacity: 0; animation: riseIn 0.9s 0.2s forwards; }
  .hero-h1 { font-family: var(--font-display); font-size: clamp(2.8rem, 6.5vw, 5.2rem); font-weight: 300; line-height: 1.08; color: var(--plum-deep); letter-spacing: -0.01em; margin-bottom: 28px; opacity: 0; animation: riseIn 0.9s 0.4s forwards; }
  .hero-h1 em { font-style: italic; font-weight: 400; color: var(--rose); }
  .hero-sub { font-size: clamp(0.98rem, 1.6vw, 1.12rem); font-weight: 300; color: var(--text-light); max-width: 580px; margin: 0 auto 42px; line-height: 1.85; opacity: 0; animation: riseIn 0.9s 0.6s forwards; }
  .hero-btns { display: flex; gap: 14px; justify-content: center; flex-wrap: wrap; opacity: 0; animation: riseIn 0.9s 0.8s forwards; }
  .hero-scroll { position: absolute; bottom: 36px; left: 50%; transform: translateX(-50%); display: flex; flex-direction: column; align-items: center; gap: 8px; opacity: 0; animation: riseIn 0.9s 1.2s forwards; }
  .hero-scroll span { font-size: 0.68rem; letter-spacing: 0.16em; text-transform: uppercase; color: var(--text-light); }
  .scroll-pip { width: 1px; height: 36px; background: linear-gradient(to bottom, var(--rose), transparent); animation: pulse-line 2.2s ease-in-out infinite; }
  @keyframes pulse-line { 0%, 100% { opacity: 0.25; transform: scaleY(0.5); } 50% { opacity: 1; transform: scaleY(1); } }
  @keyframes riseIn { from { opacity: 0; transform: translateY(28px); } to { opacity: 1; transform: translateY(0); } }

  /* Tagline */
  .tagline-banner { position: relative; padding: clamp(56px, 7vw, 96px) clamp(20px, 5vw, 80px); background: var(--warm-white); overflow: hidden; }
  .tagline-inner { max-width: 820px; margin: 0 auto; text-align: center; position: relative; z-index: 2; }
  .tagline-deco { display: flex; align-items: center; justify-content: center; gap: 14px; margin-bottom: 36px; }
  .tagline-deco .line { width: 56px; height: 1px; background: linear-gradient(to right, transparent, var(--rose-soft), transparent); }
  .tagline-deco .diamond { width: 7px; height: 7px; background: var(--rose-soft); transform: rotate(45deg); }
  .tagline-text { font-family: var(--font-display); font-size: clamp(1.35rem, 2.8vw, 1.85rem); font-weight: 300; font-style: italic; line-height: 1.55; color: var(--plum-deep); max-width: 700px; margin: 0 auto 24px; }
  .tagline-text strong { font-weight: 500; color: var(--rose); font-style: normal; }
  .tagline-attr { font-family: var(--font-accent); font-size: 1.3rem; color: var(--rose); }
  .tagline-bg-accent { position: absolute; width: 400px; height: 400px; border-radius: 50%; filter: blur(120px); opacity: 0.08; pointer-events: none; }
  .tagline-bg-accent.left { background: var(--lavender); top: -30%; left: -10%; }
  .tagline-bg-accent.right { background: var(--coral-warm); bottom: -40%; right: -8%; }

  /* Intro */
  .intro { background: var(--cream); }
  .intro-grid { display: grid; grid-template-columns: 1fr 1.15fr; gap: clamp(40px, 6vw, 100px); align-items: center; }
  .intro-img-wrap { position: relative; }
  .intro-img { width: 100%; aspect-ratio: 3/4; border-radius: 180px 180px 20px 20px; overflow: hidden; position: relative; background: linear-gradient(150deg, var(--blush) 0%, var(--lavender-soft) 50%, var(--sky-pale) 100%); }
  .intro-img::before { content: ''; position: absolute; inset: -10px; border-radius: 190px 190px 30px 30px; border: 1px solid var(--rose-pale); z-index: -1; }
  .intro-img-accent { position: absolute; bottom: -16px; right: -16px; width: 110px; height: 110px; border-radius: 50%; background: linear-gradient(135deg, var(--coral-warm), var(--rose)); opacity: 0.14; filter: blur(2px); }
